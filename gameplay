local MinigameHandlers = {
    
    -- 🟢 GAME 1: RED LIGHT GREEN LIGHT (BYPASS MODE)
    ["RedLightGreenLight"] = function()
        print("🚦 Red Light Green Light Detected! (Bypass Mode)")
        print("⏳ Waiting 16 seconds for barriers to drop...")
        
        task.wait(16)
        
        local char = getCharacter()
        local root = char:FindFirstChild("HumanoidRootPart")
