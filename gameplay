end

-- ✨ UPGRADED: Bulletproof Teleport Logic (pcall + retry loop)
local function teleportToLobby(reason)
    warn("🔙 Teleporting to lobby: " .. reason)
    
    local success = false
    while not success do
        success = pcall(function()
            TeleportService:Teleport(LOBBY_PLACE_ID, plr)
        end)
        
        if not success then
            warn("⚠️ Teleport failed! Retrying in 3 seconds...")
            task.wait(3) 
        end
    end
end

