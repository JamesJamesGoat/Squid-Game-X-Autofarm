            print("🏃‍♂️ Bypassing Red Light! Walking straight to the finish line...")
            
            while workspace.Map:FindFirstChild("RedLightGreenLight") do
                humanoid:MoveTo(Vector3.new(targetX, root.Position.Y, root.Position.Z))
                
                if math.abs(root.Position.X - targetX) <= 5 then
                    print("✅ Reached the finish line safe zone!")
