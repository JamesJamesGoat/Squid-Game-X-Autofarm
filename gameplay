    -- 🧩 GAME 6: HIDE & SEEK (VESTS & SAFE ZONE)
    ["HideNSeek"] = function()
        print("👕 HideNSeek Detected - Initiating Vest Trading & Evasion...")
        
        -- 🎯 YOUR TARGET TEAM (Change to "red" or "blue" for live farming)
        local TARGET_COLOR = "blue" 
        
        local char = getCharacter()
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local function getMyVestColor()
            if char:FindFirstChild("Vest_red") then return "red" end
            if char:FindFirstChild("Vest_blue") then return "blue" end
            return nil
        end

        -- // 1. WAIT FOR INITIAL VEST //
        print("⏳ Waiting for initial vest assignment...")
        while task.wait(0.5) and workspace.Map:FindFirstChild("HideNSeek") do
            if getMyVestColor() then break end
        end
        
        if not workspace.Map:FindFirstChild("HideNSeek") then return end
        print("👕 You were assigned: " .. string.upper(getMyVestColor()))

        -- // 2. WAIT FOR PROMPTS TO APPEAR //
        print("⏳ Waiting for Team Trade Prompts to spawn...")
        local promptsAreReady = false
        while not promptsAreReady and workspace.Map:FindFirstChild("HideNSeek") do
            task.wait(1)
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.HumanoidRootPart:FindFirstChild("TeamTradePrompt") then
                    promptsAreReady = true
                    break
                end
            end
        end

        if not workspace.Map:FindFirstChild("HideNSeek") then return end
        print("🚨 Prompts detected! Waiting 2 seconds for server stability...")
        task.wait(2)

        -- // 3. AGGRESSIVE TRADE LOOP WITH ACTIVE WAIT //
        local targetVestName = "Vest_" .. TARGET_COLOR

        if getMyVestColor() == TARGET_COLOR then
            print("🎯 Lucky spawn! You already got the " .. string.upper(TARGET_COLOR) .. " team. No need to trade.")
        else
            while getMyVestColor() ~= TARGET_COLOR and workspace.Map:FindFirstChild("HideNSeek") do
                print("🔄 Sending trade requests to EVERY " .. TARGET_COLOR .. " player...")
                local promptsStillExist = false
                
                for _, otherPlayer in ipairs(Players:GetPlayers()) do
                    if getMyVestColor() == TARGET_COLOR then break end
                    
                    if otherPlayer ~= plr and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local otherChar = otherPlayer.Character
                        
                        if otherChar:FindFirstChild(targetVestName) then
                            local tradePrompt = otherChar.HumanoidRootPart:FindFirstChild("TeamTradePrompt")
                            
                            if tradePrompt then
                                promptsStillExist = true
                                
                                if otherChar.HumanoidRootPart.Position.Y >= 16 then
                                    print("🚀 Jumping to " .. otherPlayer.Name .. "...")
                                    root.CFrame = otherChar.HumanoidRootPart.CFrame * CFrame.new(0, 0, 1)
                                    task.wait(0.3) 
                                    fireproximityprompt(tradePrompt)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                end
                
                -- Did someone accept instantly?
                if getMyVestColor() == TARGET_COLOR then
                    print("🎯 Success! Trade completed. You are now on the " .. string.upper(TARGET_COLOR) .. " team.")
                    break
                end
                
                -- Did the timer run out?
                if not promptsStillExist then
                    print("⚠️ Prompts vanished before we could get the target team.")
                    break
                end
                
                -- ⚡ The Active Wait Loop (5 seconds total)
                print("⏳ Still wrong team. Watching for late accepts for 5 seconds...")
                for i = 1, 10 do
                    task.wait(0.5)
                    if getMyVestColor() == TARGET_COLOR then
                        print("⚡ Wake up! Someone accepted the trade early!")
                        break -- Shatter the wait loop!
                    end
                end
            end

            -- ✨ Catch the Late Accept
            if getMyVestColor() == TARGET_COLOR then
                print("🎯 Success (Late Accept)! You are safely on the " .. string.upper(TARGET_COLOR) .. " team.")
            end
        end

        -- // 4. WAIT FOR PROMPTS TO DISAPPEAR //
        print("⏳ Waiting for all trade prompts to despawn...")
        local promptsExist = true
        while promptsExist and workspace.Map:FindFirstChild("HideNSeek") do
            promptsExist = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.HumanoidRootPart:FindFirstChild("TeamTradePrompt") then
                    promptsExist = true
                    break
                end
            end
            if promptsExist then task.wait(1) end
        end

        if not workspace.Map:FindFirstChild("HideNSeek") then return end
        print("🛑 Prompts are gone! Waiting 15 seconds before moving to safe zone...")
        task.wait(15)

        -- // 5. SAFE ZONE & ANTI-FALL MANEUVER //
        local BASE_X, BASE_Y, BASE_Z = -822, 40, 337
        local rng = Random.new() -- Initiating Roblox's modern, smooth randomizer

        local function getSafeCFrame()
            -- NextNumber generates true decimals so you never stand on the same pixel
            local offsetX = rng:NextNumber(-50, 50)
            local offsetZ = rng:NextNumber(-50, 50)
            return CFrame.new(BASE_X + offsetX, BASE_Y, BASE_Z + offsetZ)
        end

        if workspace.Map:FindFirstChild("HideNSeek") then
            root.CFrame = getSafeCFrame()
            print("🚀 Teleported to 50-Stud Safe Zone!")
        end

        while workspace.Map:FindFirstChild("HideNSeek") do
            task.wait(1)
            if root and root.Position.Y < 16 then
                print("⚠️ Dropped below Y=16! Snapping back to safe zone...")
                root.CFrame = getSafeCFrame()
            end
        end

        print("🏁 HideNSeek cleared!")
    end,
}

local function getActiveMinigame()
    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then return nil end

    if mapFolder:FindFirstChild("RedLightGreenLight") then return "RedLightGreenLight" end
    if mapFolder:FindFirstChild("Honeycomb") then return "Honeycomb" end
    if mapFolder:FindFirstChild("NightBrawl") then return "NightBrawl" end 
    if mapFolder:FindFirstChild("Pentathlon") then return "Pentathlon" end 
    if mapFolder:FindFirstChild("Rebellion") then return "Rebellion" end 
    if mapFolder:FindFirstChild("HideNSeek") then return "HideNSeek" end 
    
    return nil 
end

-- // ========================================================================
-- // 5. MASTER LOOP
-- // ========================================================================
local farmThread = nil

local function startPlayerLoop()
    print("🚀 Starting Player Mode Master Loop...")
    farmThread = task.spawn(function()
        while task.wait(1) do
            local activeGame = getActiveMinigame()
            if activeGame and MinigameHandlers[activeGame] then
                 MinigameHandlers[activeGame]()
            end
        end
    end)
end

local function setupCharacter(character)
    if farmThread then task.cancel(farmThread); farmThread = nil end

    -- Wait a moment for the character to fully load into the workspace
    task.wait(2)
    startPlayerLoop()
end

-- // ========================================================================
-- // 6. AUTO-JOIN
-- // ========================================================================
local function Main()
    print("✅ Script Loaded - Attempting Auto-Join...")
    local teamRemote = repStorage:WaitForChild("Remotes", 20):WaitForChild("PlayerTeam", 20)

    if teamRemote then
        teamRemote:FireServer()
        task.wait(1)
    end

    plr.CharacterAdded:Connect(setupCharacter)
    if plr.Character then setupCharacter(plr.Character) end
end

Main()
